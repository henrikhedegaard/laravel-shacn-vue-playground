    "tailwindcss": "^4.1.1",
    "tw-animate-css": "^1.2.5",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.4",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  }
