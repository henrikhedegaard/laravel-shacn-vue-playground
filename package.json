{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "vite build",
    "build:ssr": "vite build && vite build --ssr",
    "dev": "vite",
    "format": "oxfmt resources/",
    "format:check": "oxfmt --check resources/",
    "lint": "oxlint resources/ --fix",
